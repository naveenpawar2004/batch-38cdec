pipeline {
    agent any

    stages {
        stage('pull-stage') {
            steps {
                git branch: 'main', url: 'https://github.com/naveenpawar2004/terraform-file.git'
            }
        }
         stage('init-stage') {
            steps {
                sh '''terraform init
                      terraform plan'''
            }
        }
         stage('approve-stage') {
            steps {
                input massage: 'Shall we procced ?', ok: 'approve'
            }
        } 
         stage('apply-stage') {
            steps {
                sh 'terraform apply --auto-approve'
            }
        }
    }
}
